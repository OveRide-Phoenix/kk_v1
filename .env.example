# ══════════════════════════════════════════════
# Kuteera Kitchen — environment variables.
# Copy the relevant section to the right .env file.
# ══════════════════════════════════════════════


# ──────────────────────────────────────────────
# Frontend (Next.js)  →  .env.local
# ──────────────────────────────────────────────

# Internal URL Next.js uses to proxy /api/backend/* → FastAPI.
# Local:       http://127.0.0.1:8000
# Production:  http://your-internal-fastapi-host:8000  (never expose port publicly)
BACKEND_URL=http://127.0.0.1:8000

# JWT signing secret — must match SECRET_KEY in backend/.env exactly.
# Used by Next.js middleware to verify auth cookies locally without a backend round-trip.
JWT_SECRET=change-me-in-production


# ──────────────────────────────────────────────
# Backend (FastAPI)  →  backend/.env
# ──────────────────────────────────────────────

# MySQL connection string
DATABASE_URL=mysql+pymysql://fastapi_user:password@localhost/kk_v1

# JWT signing secret — use a long random string in production
SECRET_KEY=change-me-in-production

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie settings
# Set COOKIE_SECURE=true in production — NGINX terminates HTTPS so FastAPI runs
# on plain HTTP internally, but cookies must still be marked Secure for the browser.
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# Optional: custom domain for cookie binding
BACKEND_DOMAIN=

# FastAPI root path when served behind the /api/backend reverse-proxy prefix
# Local: leave empty
# Dev/Production: /api/backend
API_ROOT_PATH=

# Google Gemini API key (used for NL query features)
GEMINI_API_KEY=
