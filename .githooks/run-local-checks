#!/usr/bin/env bash
# Shared local quality gate for Git hooks and pre-MR checks.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
skip() { echo -e "  ${YELLOW}–${RESET} $1 ${YELLOW}(skipped)${RESET}"; }
fix() { echo -e "  ${YELLOW}↻${RESET} $1"; }

FIX_MODE=0
if [ "${1:-}" = "--fix" ]; then
  FIX_MODE=1
fi

echo -e "\n${BOLD}Local checks${RESET}"
echo "──────────────────────────────"

FAILED=0

# ── Python formatting ────────────────────────────────────────────────────────
BLACK_BIN="./backend/venv/bin/black"
[ ! -x "$BLACK_BIN" ] && BLACK_BIN="$(command -v black 2>/dev/null || true)"

if [ -z "$BLACK_BIN" ]; then
  skip "Black not found"
  echo "    Install it with: ./backend/venv/bin/pip install black==24.10.0"
elif [ "$FIX_MODE" -eq 1 ]; then
  "$BLACK_BIN" --line-length 100 backend/
  pass "Black format"
elif "$BLACK_BIN" --check --line-length 100 backend/; then
  pass "Black"
else
  fail "Black formatting"
  echo "    Fix with: $BLACK_BIN --line-length 100 backend/"
  FAILED=1
fi

# ── Python linting, if configured locally ────────────────────────────────────
RUFF_BIN="./backend/venv/bin/ruff"
[ ! -x "$RUFF_BIN" ] && RUFF_BIN="$(command -v ruff 2>/dev/null || true)"

if [ -z "$RUFF_BIN" ]; then
  skip "Ruff not found"
elif [ "$FIX_MODE" -eq 1 ]; then
  "$RUFF_BIN" check --fix backend/
  pass "Ruff fix"
elif "$RUFF_BIN" check backend/; then
  pass "Ruff"
else
  fail "Ruff"
  FAILED=1
fi

# ── Frontend linting ─────────────────────────────────────────────────────────
if [ "$FIX_MODE" -eq 1 ]; then
  npx eslint src --fix
  fix "ESLint auto-fix"
fi

if npm run lint --silent; then
  pass "ESLint"
else
  fail "ESLint"
  FAILED=1
fi

# ── TypeScript ───────────────────────────────────────────────────────────────
if npx tsc --noEmit; then
  pass "TypeScript"
else
  fail "TypeScript"
  FAILED=1
fi

echo "──────────────────────────────"

if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}Local checks failed.${RESET}"
  exit 1
fi

echo -e "${GREEN}All local checks passed.${RESET}\n"
exit 0
