#!/usr/bin/env bash
# Pre-push hook: fast local checks.
#
# Runs the same practical quality checks you would run by hand:
#   - Black check for backend Python formatting
#   - Ruff check for backend Python if Ruff is installed
#   - ESLint for frontend
#   - TypeScript typecheck
#
# Skip entirely: SKIP_HOOKS=1 git push

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
skip() { echo -e "  ${YELLOW}–${RESET} $1 ${YELLOW}(skipped)${RESET}"; }

if [ "${SKIP_HOOKS:-}" = "1" ]; then
  echo -e "${YELLOW}Pre-push hooks skipped (SKIP_HOOKS=1)${RESET}"
  exit 0
fi

echo -e "\n${BOLD}Pre-push local checks${RESET}"
echo "──────────────────────────────"

FAILED=0

# ── Python formatting ────────────────────────────────────────────────────────
BLACK_BIN="./backend/venv/bin/black"
[ ! -x "$BLACK_BIN" ] && BLACK_BIN="$(command -v black 2>/dev/null || true)"

if [ -z "$BLACK_BIN" ]; then
  skip "Black not found"
  echo "    Install it with: ./backend/venv/bin/pip install black==24.10.0"
elif "$BLACK_BIN" --check --line-length 100 backend/; then
  pass "Black"
else
  fail "Black formatting"
  echo "    Fix with: $BLACK_BIN --line-length 100 backend/"
  FAILED=1
fi

# ── Python linting, if configured locally ────────────────────────────────────
RUFF_BIN="./backend/venv/bin/ruff"
[ ! -x "$RUFF_BIN" ] && RUFF_BIN="$(command -v ruff 2>/dev/null || true)"

if [ -z "$RUFF_BIN" ]; then
  skip "Ruff not found"
elif "$RUFF_BIN" check backend/; then
  pass "Ruff"
else
  fail "Ruff"
  FAILED=1
fi

# ── Frontend linting ─────────────────────────────────────────────────────────
if npm run lint --silent; then
  pass "ESLint"
else
  fail "ESLint"
  FAILED=1
fi

# ── TypeScript ───────────────────────────────────────────────────────────────
if npx tsc --noEmit; then
  pass "TypeScript"
else
  fail "TypeScript"
  FAILED=1
fi

echo "──────────────────────────────"

if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}Push blocked — fix the local check failures above.${RESET}"
  echo -e "Skip hooks: ${YELLOW}SKIP_HOOKS=1 git push${RESET}"
  exit 1
fi

echo -e "${GREEN}All local checks passed — pushing.${RESET}\n"
exit 0
