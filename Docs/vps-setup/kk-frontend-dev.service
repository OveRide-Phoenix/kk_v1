[Unit]
Description=Kuteera Kitchen Next.js Frontend (DEV)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/kk_v1_dev
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kk-frontend-dev
Environment=NODE_ENV=production
Environment=PORT=3001

[Install]
WantedBy=multi-user.target
