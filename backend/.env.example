# ══════════════════════════════════════════════
# Kuteera Kitchen — Backend environment variables
# Copy to backend/.env and fill in real values.
# ══════════════════════════════════════════════

# MySQL connection string
# LOCAL:  mysql+pymysql://fastapi_user:password@localhost/kk_v1
# DEV:    mysql+pymysql://fastapi_user:password@localhost/kk_v1_dev
# PROD:   mysql+pymysql://fastapi_user:password@localhost/kk_v1_prod
DATABASE_URL=mysql+pymysql://fastapi_user:password@localhost/kk_v1

# JWT signing secret — use a long random string; must match JWT_SECRET in .env.local
SECRET_KEY=change-me-use-a-long-random-string

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie settings
# COOKIE_SECURE=false for LOCAL; true for DEV and PROD (NGINX terminates HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# Optional: cookie domain binding (leave empty for localhost)
BACKEND_DOMAIN=

# Allowed CORS origins — comma-separated, no trailing slashes
# LOCAL:  http://127.0.0.1:3000,http://localhost:3000
# DEV:    https://dev.yourdomain.com
# PROD:   https://yourdomain.com
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Google Gemini API key (used for NL query features — optional)
GEMINI_API_KEY=
